# ─── Roman CRM ───
# Lead intake endpoint. Add X-API-Key header to authenticate.
CRM_API_URL=https://heartlandboys.com/api/v1/leads/
# Shared secret between this app and the Roman CRM's LEAD_API_KEY env var.
# Generate with: openssl rand -hex 32
CRM_API_KEY=

# ─── Google ───
# GA4 Measurement ID (preserved from current site)
NEXT_PUBLIC_GA4_ID=G-9EZ5K28HE0
# Google Ads (conversion tracking)
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-17998492916
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=
# Google Ads API credentials (for Enhanced Conversions upload)
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ─── Meta ───
# Pixel ID (preserved from current site)
NEXT_PUBLIC_META_PIXEL_ID=985500610829308
# CAPI server-side event token
META_CAPI_TOKEN=

# ─── Cloudflare Turnstile ───
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── PostHog ───
NEXT_PUBLIC_POSTHOG_KEY=
